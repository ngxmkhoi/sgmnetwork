# ============================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!
# NEVER share this file with unauthorized persons!
# ============================================================

# SUPABASE AUTHENTICATION & DATABASE
# Get from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# SITE URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# EMAIL DELIVERY FOR ADMIN INVITATIONS
# Get API key from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxx
ADMIN_INVITE_FROM_EMAIL=SGM Network Admin <noreply@your-domain.com>
ADMIN_INVITE_REPLY_TO_EMAIL=support@your-domain.com

# DATABASE CONFIGURATION
DISABLE_SUPABASE_RUNTIME=false
SUPABASE_QUERY_TIMEOUT_MS=8000

# ============================================================
# PRODUCTION DEPLOYMENT
# ============================================================
# For Vercel production:
# NEXT_PUBLIC_SITE_URL=https://sgmnetwork.vercel.app
