# ============================================================
# SGM NETWORK V1 - ENVIRONMENT VARIABLES
# © 2026 SGM Network. All Rights Reserved.
# PROPRIETARY SOFTWARE - Private Repository Only
# ============================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to Git!
# NEVER share this file with unauthorized persons!
# ============================================================

# SUPABASE AUTHENTICATION & DATABASE
# Get from: https://app.supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# SITE URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# EMAIL DELIVERY FOR ADMIN INVITATIONS
# Get API key from: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxx
ADMIN_INVITE_FROM_EMAIL=SGM Network Admin <noreply@your-domain.com>
ADMIN_INVITE_REPLY_TO_EMAIL=support@your-domain.com

# GMAIL SMTP FOR CONTACT FORM
# Dùng Gmail App Password (không phải mật khẩu thường)
# Bật tại: https://myaccount.google.com → Security → 2-Step Verification → App passwords
GMAIL_USER=sgmnetwork24@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# DATABASE CONFIGURATION
DISABLE_SUPABASE_RUNTIME=false
SUPABASE_QUERY_TIMEOUT_MS=8000

# ============================================================
# PRODUCTION DEPLOYMENT
# ============================================================
# For Vercel production:
# NEXT_PUBLIC_SITE_URL=https://sgmnetwork.vercel.app

# GOOGLE SHEETS - Đánh giá bài viết
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
